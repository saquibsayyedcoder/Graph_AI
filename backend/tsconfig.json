{
  "compilerOptions": {
    "target": "ES2020",

    // ✅ FIX THESE TWO TOGETHER
    "module": "Node16",
    "moduleResolution": "Node16",

    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}